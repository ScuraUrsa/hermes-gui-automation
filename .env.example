# ============================================
# Hermes GUI Automation — Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to the repository.
# ============================================

# Display Server
DISPLAY=:99
XVFB_RESOLUTION=1920x1080x24
XVFB_SCREEN=0

# GUI Automation Timeouts (seconds)
GUI_DEFAULT_TIMEOUT=30
GUI_CLICK_TIMEOUT=10
GUI_TYPE_INTERVAL=0.01
GUI_WAIT_TIMEOUT=30

# OCR
TESSERACT_LANGUAGES=eng,pol,deu,fra,spa
TESSERACT_DATA_DIR=/usr/share/tesseract-ocr/5/tessdata
OCR_FALLBACK_LANGUAGE=eng

# VLM Models
FLORENCE_MODEL=microsoft/Florence-2-base
FLORENCE_DEVICE=cpu
OMNIPARSER_MODEL=microsoft/OmniParser
OMNIPARSER_DEVICE=cpu

# Browser
PLAYWRIGHT_BROWSERS=chromium,firefox
BROWSER_HEADLESS=true

# Screenshot Logging
GUI_SCREENSHOT_DIR=/tmp/hermes-gui
GUI_SCREENSHOT_LOG_ENABLED=true

# AT-SPI2
ATSPI_BUS_ADDRESS=unix:path=/run/user/1000/at-spi/bus
ATSPI_REGISTRYD_ENABLED=true

# Test Configuration
TEST_XVFB_DISPLAY=:99
TEST_APP_TIMEOUT=15
TEST_BROWSER_TIMEOUT=30
